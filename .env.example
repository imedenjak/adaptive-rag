OPENAI_API_KEY=sk-xxx
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_QUERY_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
FAST_EMBED_SPARSE=Qdrant/bm25
# OPENAI_EMBEDDING_DIMENSIONS=1536

# PostgreSQL chat history (Docker Compose sets this automatically for containerised runs)
DATABASE_URL=postgresql://rag:rag@localhost:5432/chat

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=rag_docs
PYTHONPATH=app

# Authentication — set to enable password gate on the Streamlit UI (leave unset to disable)
# APP_PASSWORD=changeme

# Logging — "dev" for colored console output, "json" for production log aggregators
LOG_LEVEL=INFO
LOG_FORMAT=dev

# LangSmith tracing
LANGCHAIN_TRACING_V2=true
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGCHAIN_API_KEY=lsv2_xxx
LANGCHAIN_PROJECT=adaptive-rag

# Ollama — set USE_OLLAMA=true to use local Ollama instead of OpenAI for chat and embeddings
# USE_OLLAMA=true
# OLLAMA_CHAT_MODEL=qwen2.5:14b
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# OLLAMA_BASE_URL=http://host.docker.internal:11434
